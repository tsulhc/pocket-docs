---
/**
 * Landing page — hero + persona cards + sidebar navigation.
 * Uses three-column layout with sidebar for navigation context.
 * Hero + stat bar + persona cards appear in the main content area.
 */
import '../styles/global.css';
import SidebarNav from '../components/SidebarNav.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pocket Network Docs</title>
  <meta name="description" content="Official documentation for Pocket Network — decentralized infrastructure for accessing any open data, anywhere." />
  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}pokt-icon.png`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- FOUC prevention -->
  <script is:inline>
    var s = localStorage.getItem('theme');
    var p = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', s || p);
  </script>

  <!-- Header (matches DocsLayout) -->
  <header class="site-header">
    <div class="header-inner">
      <a href={import.meta.env.BASE_URL} class="header-logo">
        <img src={`${import.meta.env.BASE_URL}logo-black.svg`} alt="Pocket Network" class="logo-light" height="28" />
        <img src={`${import.meta.env.BASE_URL}logo-white.svg`} alt="Pocket Network" class="logo-dark" height="28" />
        <span class="docs-badge">Docs</span>
      </a>
      <div class="search-input-wrapper" id="search-wrapper">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" class="search-input" placeholder="Search docs…" aria-label="Search documentation" />
        <span class="search-kbd">⌘K</span>
      </div>
      <nav class="header-nav">
        <a class="header-external-link" href="https://github.com/pokt-network" target="_blank" rel="noopener">GitHub</a>
        <a class="header-external-link" href="http://discord.gg/pocket-network" target="_blank" rel="noopener">Discord</a>
        <div class="theme-toggle" id="theme-toggle">
          <button id="theme-light-btn" aria-pressed="false">☀<span class="theme-label"> Light</span></button>
          <button id="theme-dark-btn" aria-pressed="false">☽<span class="theme-label"> Dark</span></button>
        </div>
      </nav>
      <button class="search-toggle-btn" id="search-toggle" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Open navigation" aria-expanded="false">
        <svg class="icon-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="mobile-search-bar" id="mobile-search-bar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="search" class="search-input" placeholder="Search docs…" aria-label="Search documentation" id="mobile-search-input" />
    </div>
  </header>
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

  <!-- Page layout with sidebar -->
  <div class="page-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <nav aria-label="Documentation navigation">
        <SidebarNav currentPath="/" />
      </nav>
      <div class="sidebar-mobile-footer">
        <a href="https://github.com/pokt-network" target="_blank" rel="noopener" class="sidebar-link">GitHub ↗</a>
        <a href="http://discord.gg/pocket-network" target="_blank" rel="noopener" class="sidebar-link">Discord ↗</a>
      </div>
    </aside>

    <!-- Main content -->
    <main id="main-content" class="main-content">
      <!-- Hero -->
      <div class="hero-mock">
        <div class="hero-content">
          <h2>Pocket Network <span>Documentation</span></h2>
          <p>Fully permissionless, fully decentralized open data delivery. 5,000+ independent nodes. 60+ blockchains. No API key required.</p>
          <a href={`${b}/get-started/what-is-pocket`} style="display:inline-block;background:var(--brand-blue);color:#fff;padding:var(--space-3) var(--space-6);border-radius:var(--radius-full);font-weight:var(--weight-semibold);font-size:var(--text-sm);text-decoration:none;transition:background var(--transition-fast);">
            Get Started →
          </a>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="feature-grid" style="margin: var(--space-10) 0;">
        <div class="feature-item">
          <div class="feature-number" style="color: var(--brand-blue);">5,000+</div>
          <div class="feature-label">Independent nodes</div>
        </div>
        <div class="feature-item">
          <div class="feature-number" style="color: var(--brand-blue);">60+</div>
          <div class="feature-label">Supported blockchains</div>
        </div>
        <div class="feature-item">
          <div class="feature-number" style="color: var(--brand-blue);">0</div>
          <div class="feature-label">API keys required</div>
        </div>
      </div>

      <!-- Persona cards -->
      <h2 style="font-size:var(--text-2xl);font-weight:var(--weight-bold);color:var(--text-primary);margin-bottom:var(--space-6);">Find your path</h2>
      <div class="card-grid" style="margin-bottom: var(--space-12);">
        <a href={`${b}/developers`} class="card persona">
          <svg width="64" height="64" viewBox="0 0 64 64" class="card-icon-svg"><rect width="64" height="64" rx="14" fill="#025af2" opacity=".12"/><g stroke="#025af2" stroke-width="2" stroke-linecap="round" fill="none"><polyline points="22,24 16,32 22,40"/><polyline points="42,24 48,32 42,40"/><line x1="36" y1="20" x2="28" y2="44"/></g></svg>
          <h4>Application Developers</h4>
          <p>Get an RPC endpoint and start querying blockchains in under 60 seconds.</p>
          <span class="card-link">Start building →</span>
        </a>
        <a href={`${b}/node-operators`} class="card persona">
          <svg width="64" height="64" viewBox="0 0 64 64" class="card-icon-svg"><rect width="64" height="64" rx="14" fill="#ffc547" opacity=".15"/><g stroke="#b8860b" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="22" y="20" width="20" height="24" rx="3"/><line x1="26" y1="26" x2="38" y2="26"/><line x1="26" y1="31" x2="38" y2="31"/><circle cx="32" cy="38" r="2" fill="#b8860b"/><line x1="32" y1="44" x2="32" y2="50"/><line x1="26" y1="50" x2="38" y2="50"/></g></svg>
          <h4>Node Operators</h4>
          <p>Run a Supplier, stake POKT, and earn rewards for serving data.</p>
          <span class="card-link">Run a node →</span>
        </a>
        <a href={`${b}/gateways`} class="card persona">
          <svg width="64" height="64" viewBox="0 0 64 64" class="card-icon-svg"><rect width="64" height="64" rx="14" fill="#48e5c2" opacity=".15"/><g stroke="#0f6e56" stroke-width="2" fill="none" stroke-linecap="round"><circle cx="32" cy="32" r="6"/><circle cx="32" cy="32" r="14" stroke-dasharray="4 3"/><line x1="32" y1="12" x2="32" y2="18"/><line x1="32" y1="46" x2="32" y2="52"/><line x1="12" y1="32" x2="18" y2="32"/><line x1="46" y1="32" x2="52" y2="32"/></g></svg>
          <h4>Gateway Operators</h4>
          <p>Deploy PATH and run your own decentralized open data gateway.</p>
          <span class="card-link">Deploy a gateway →</span>
        </a>
        <a href={`${b}/token`} class="card persona">
          <svg width="64" height="64" viewBox="0 0 64 64" class="card-icon-svg"><rect width="64" height="64" rx="14" fill="#025af2" opacity=".12"/><g stroke="#025af2" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="30" r="10"/><text x="32" y="34" text-anchor="middle" font-family="Rubik,sans-serif" font-size="12" font-weight="700" fill="#025af2" stroke="none">P</text><path d="M22 42 Q22 48 32 50 Q42 48 42 42"/></g></svg>
          <h4>Token Holders</h4>
          <p>Buy, stake, delegate, and manage POKT across chains and wallets.</p>
          <span class="card-link">Explore POKT →</span>
        </a>
        <a href={`${b}/protocol`} class="card persona">
          <svg width="64" height="64" viewBox="0 0 64 64" class="card-icon-svg"><rect width="64" height="64" rx="14" fill="#b8b8ff" opacity=".2"/><g stroke="#534ab7" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="20" r="4" fill="#534ab7"/><line x1="32" y1="24" x2="32" y2="36"/><circle cx="24" cy="40" r="4" fill="#534ab7"/><circle cx="40" cy="40" r="4" fill="#534ab7"/><line x1="32" y1="36" x2="24" y2="36"/><line x1="24" y1="36" x2="24" y2="40"/><line x1="32" y1="36" x2="40" y2="36"/><line x1="40" y1="36" x2="40" y2="40"/><line x1="24" y1="44" x2="24" y2="50"/></g></svg>
          <h4>Protocol Contributors</h4>
          <p>Dive into the Shannon protocol, contribute code, and understand tokenomics.</p>
          <span class="card-link">Read the protocol →</span>
        </a>
        <a href={`${b}/governance`} class="card persona">
          <svg width="64" height="64" viewBox="0 0 64 64" class="card-icon-svg"><rect width="64" height="64" rx="14" fill="#ff5a5f" opacity=".12"/><g stroke="#993556" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M20 42 L32 18 L44 42 Z"/><line x1="24" y1="36" x2="40" y2="36"/><line x1="32" y1="42" x2="32" y2="50"/><line x1="24" y1="50" x2="40" y2="50"/></g></svg>
          <h4>Governance</h4>
          <p>Understand the DAO, vote on proposals, and shape Pocket's future.</p>
          <span class="card-link">Join governance →</span>
        </a>
      </div>

      <!-- Quick links -->
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-semibold);color:var(--text-primary);margin-bottom:var(--space-4);">Quick links</h2>
      <div style="display:flex;flex-wrap:wrap;gap:var(--space-3);margin-bottom:var(--space-12);">
        {[
          { label: 'What is Pocket?', href: `${b}/get-started/what-is-pocket` },
          { label: 'Available Networks', href: `${b}/developers/supported-chains` },
          { label: 'Install pocketd', href: `${b}/get-started/pocketd-installation` },
          { label: 'Shannon Upgrade', href: `${b}/get-started/shannon-upgrade` },
          { label: 'API Portal', href: `${b}/foundation/api-portal` },
          { label: 'Glossary', href: `${b}/reference/glossary` },
        ].map(({ label, href }) => (
          <a href={href} style="background:var(--bg-tertiary);border:1px solid var(--border-primary);color:var(--text-secondary);padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);font-size:var(--text-sm);text-decoration:none;transition:all var(--transition-fast);">
            {label}
          </a>
        ))}
      </div>
    </main>
  </div>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <p>© {new Date().getFullYear()} Pocket Network Foundation</p>
      <nav>
        <a href="https://pocket.network" target="_blank" rel="noopener">pocket.network</a>
        <a href="https://github.com/pokt-network" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
  </footer>

  <!-- Theme toggle script (same logic as DocsLayout) -->
  <script is:inline>
    (function () {
      function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        var l = document.getElementById('theme-light-btn');
        var d = document.getElementById('theme-dark-btn');
        if (l && d) {
          l.classList.toggle('active', theme === 'light');
          d.classList.toggle('active', theme === 'dark');
          l.setAttribute('aria-pressed', theme === 'light' ? 'true' : 'false');
          d.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
        }
      }
      document.addEventListener('DOMContentLoaded', function () {
        applyTheme(document.documentElement.getAttribute('data-theme') || 'light');
        var l = document.getElementById('theme-light-btn');
        var d = document.getElementById('theme-dark-btn');
        if (l) l.addEventListener('click', function () { applyTheme('light'); });
        if (d) d.addEventListener('click', function () { applyTheme('dark'); });
        // Mobile nav + search
        var menuBtn = document.getElementById('mobile-menu-btn');
        var sidebar = document.getElementById('sidebar');
        var backdrop = document.getElementById('sidebar-backdrop');
        var searchBtn = document.getElementById('search-toggle');
        var searchBar = document.getElementById('mobile-search-bar');
        var searchInput = document.getElementById('mobile-search-input');
        function openMenu() { sidebar.classList.add('open'); backdrop.classList.add('open'); menuBtn.classList.add('open'); menuBtn.setAttribute('aria-expanded','true'); searchBar.classList.remove('open'); }
        function closeMenu() { sidebar.classList.remove('open'); backdrop.classList.remove('open'); menuBtn.classList.remove('open'); menuBtn.setAttribute('aria-expanded','false'); }
        if (menuBtn) menuBtn.addEventListener('click', function () { sidebar.classList.contains('open') ? closeMenu() : openMenu(); });
        if (backdrop) backdrop.addEventListener('click', closeMenu);
        if (searchBtn) searchBtn.addEventListener('click', function () { var isOpen = searchBar.classList.toggle('open'); if (isOpen) { closeMenu(); setTimeout(function(){searchInput&&searchInput.focus();},50); } });
      });
    })();
  </script>
</body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-height);
    background: var(--bg-header);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-primary);
  }
  .header-inner {
    max-width: var(--page-max-width);
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: 0 var(--space-5);
  }
  .header-inner .search-input-wrapper {
    flex: 1;
    max-width: 360px;
    margin: 0 var(--space-4);
  }
  .mobile-menu-btn, .search-toggle-btn {
    display: none;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    padding: var(--space-1);
  }
  .mobile-menu-btn .icon-close { display: none; }
  .mobile-menu-btn.open .icon-menu { display: none; }
  .mobile-menu-btn.open .icon-close { display: block; }
  .mobile-search-bar {
    display: none;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-primary);
  }
  .mobile-search-bar.open { display: flex; }
  .mobile-search-bar input {
    flex: 1; background: none; border: none; outline: none;
    color: var(--text-primary); font-size: var(--text-base); font-family: inherit;
  }
  .sidebar-backdrop {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.45); z-index: 39;
  }
  .sidebar-backdrop.open { display: block; }
  .sidebar-mobile-footer { display: none; flex-direction: column; border-top: 1px solid var(--border-secondary); padding: var(--space-3) 0; margin-top: var(--space-4); }
  .page-layout {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    min-height: calc(100vh - var(--header-height));
  }
  .sidebar {
    padding: var(--space-6) 0;
    border-right: 1px solid var(--border-secondary);
    background: var(--bg-sidebar);
  }
  .main-content {
    padding: var(--space-8) var(--space-10);
    min-width: 0;
  }
  .site-footer {
    border-top: 1px solid var(--border-primary);
    padding: var(--space-8) var(--space-5);
  }
  .footer-inner {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
  .footer-inner nav { display: flex; gap: var(--space-5); }
  @media (max-width: 1024px) {
    .page-layout { grid-template-columns: 1fr; max-width: 100%; }
    .header-inner { padding: 0 var(--space-3); gap: var(--space-2); }
    .header-inner .search-input-wrapper { display: none; }
    .header-external-link { display: none; }
    .theme-label { display: none; }
    .search-toggle-btn { display: flex; align-items: center; margin-left: auto; }
    .mobile-menu-btn { display: flex; align-items: center; }
    .sidebar {
      position: fixed;
      left: -100%; top: var(--header-height); bottom: 0;
      width: 85%; max-width: 320px;
      z-index: 40; overflow-y: auto;
      transition: left 0.25s ease;
      border-right: 1px solid var(--border-primary);
      box-shadow: var(--shadow-lg);
      background: var(--bg-sidebar);
    }
    .sidebar.open { left: 0; }
    .sidebar-mobile-footer { display: flex; }
    .main-content { padding: var(--space-5) var(--space-4); }
  }
  @media (max-width: 640px) {
    .main-content { padding: var(--space-4) var(--space-3); }
    .header-inner { padding: 0 var(--space-2); }
  }
</style>
